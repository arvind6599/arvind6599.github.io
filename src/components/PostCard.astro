---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  href: string;
  readingTime?: string;
}

const { title, description, date, tags = [], href, readingTime } = Astro.props;
---

<article class="card reveal">
  <a href={href} class="card-link" aria-label={title}></a>
  {tags.length > 0 && (
    <div class="card-tags">
      {tags.slice(0, 3).map(tag => (
        <span class="card-tag">{tag}</span>
      ))}
    </div>
  )}
  <h2 class="card-title">{title}</h2>
  {description && <p class="card-desc">{description}</p>}
  <div class="card-meta">
    {date && <FormattedDate date={date} format="short" />}
    {date && readingTime && <span class="card-meta-dot"></span>}
    {readingTime && <span>{readingTime}</span>}
  </div>
</article>
